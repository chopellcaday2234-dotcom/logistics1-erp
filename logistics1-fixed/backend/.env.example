# ─────────────────────────────────────────────────────────
#  LOGISTICS 1 ERP — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
APP_NAME="Logistics 1 ERP"

# Database (MySQL via XAMPP)
DATABASE_URL="mysql://root:@localhost:3306/logistics1_erp"

# JWT
JWT_SECRET=logistics1_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=logistics1_refresh_secret_key_change_in_production_2024
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# File Uploads
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# ─── Email / SMTP (optional — for forgot-password emails) ─
# Leave blank to use console-log mode in development
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Logistics 1 ERP <noreply@logistics1.com>"
